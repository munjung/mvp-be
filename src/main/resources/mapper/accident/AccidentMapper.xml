<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ktds.mvp.demo.domain.accident.mapper.AccidentMapper">

    <resultMap id="accidendResultMap" type="com.ktds.mvp.demo.domain.accident.dto.AccidentResponse">
        <id property="id" column="id"/>
        <result property="type_name" column="type_name"/>
    </resultMap>

    <select id="getAccidentList" resultMap="accidendResultMap">
        select id, type_name
        from accident
        order by id
    </select>

</mapper>